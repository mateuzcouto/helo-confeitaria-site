# QZ signing certificate (PEM). You can paste with literal newlines or escaped \n.
QZ_CERT_PEM="-----BEGIN CERTIFICATE-----\nYOUR_CERT_HERE\n-----END CERTIFICATE-----"

# Private key used to sign QZ payloads (PEM). Keep secret.
QZ_PRIVATE_KEY_PEM="-----BEGIN PRIVATE KEY-----\nYOUR_PRIVATE_KEY_HERE\n-----END PRIVATE KEY-----"

# EmailJS configuration for server-side order notification.
EMAILJS_SERVICE_ID="your_service_id"
EMAILJS_TEMPLATE_ID="your_template_id"
EMAILJS_PUBLIC_KEY="your_public_key"
EMAILJS_PRIVATE_KEY="your_private_key"

# Comma-separated list of recipients.
EMAILJS_NOTIFY_EMAILS="contato@seudominio.com,financeiro@seudominio.com"

# Comma-separated list of admin emails allowed to receive custom claim "admin".
ADMIN_ALLOWED_EMAILS="admin@seudominio.com"

# Groq API key for AI chat assistant (https://console.groq.com/keys)
GROQ_API_KEY=""
